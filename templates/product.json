img\" aria-label=\"United States flag\">\n      <rect width=\"19\" height=\"10\" fill=\"#B22234\"/>\n      <rect y=\"0.769\" width=\"19\" height=\"0.769\" fill=\"#fff\"/>\n      <rect y=\"2.308\" width=\"19\" height=\"0.769\" fill=\"#fff\"/>\n      <rect y=\"3.846\" width=\"19\" height=\"0.769\" fill=\"#fff\"/>\n      <rect y=\"5.385\" width=\"19\" height=\"0.769\" fill=\"#fff\"/>\n      <rect y=\"6.923\" width=\"19\" height=\"0.769\" fill=\"#fff\"/>\n      <rect y=\"8.462\" width=\"19\" height=\"0.769\" fill=\"#fff\"/>\n      <rect width=\"7.6\" height=\"5.385\" fill=\"#3C3B6E\"/>\n      <g fill=\"#fff\">\n        <circle cx=\"1.0\" cy=\"0.9\" r=\"0.2\"/><circle cx=\"2.3\" cy=\"0.9\" r=\"0.2\"/><circle cx=\"3.6\" cy=\"0.9\" r=\"0.2\"/><circle cx=\"4.9\" cy=\"0.9\" r=\"0.2\"/><circle cx=\"6.2\" cy=\"0.9\" r=\"0.2\"/>\n        <circle cx=\"1.0\" cy=\"2.0\" r=\"0.2\"/><circle cx=\"2.3\" cy=\"2.0\" r=\"0.2\"/><circle cxcle cx=\"4.9\" cy=\"2.0\" r=\"0.2\"/><circle cx=\"6.2\" cy=\"2.0\" r=\"0.2\"/>\n        <circle cx=\"1.0\" cy=\"3.1\" r=\"0.2\"/><circle cx=\"2.3\" cy=\"3.1\" r=\"0.2\"/><circle cx=\"3.6\" cy=\"3.1\" r=\"0.2\"/><circle cx=\"4.9\" cy=\"3.1\" r=\"0.2\"/><circle cx=\"6.2\" cy=\"3.1\" r=\"0.2\"/>\n        <circle cx=\"1.0\" cy=\"4.2\" r=\"0.2\"/><circle cx=\"2.3\" cy=\"4.2\" r=\"0.2\"/><circle cx=\"3.6\" cy=\"4.2\" r=\"0.2\"/><circle cx=\"4.9\" cy=\"4.2\" r=\"0.2\"/><circle cx=\"6.2\" cy=\"4.2\" r=\"0.2\"/>\n      </g>\n    </svg>\n    <span><strong>Free</strong> Shipping</span>\n  </div>\n</div>\n\n<script>\n  (function() {\n    // Current date in the United States (Eastern time)\n    const now = new Date();\n\n    // Calculate the next day using a US time zone\n    const parts = new Intl.DateTimeFormat('en-US', {\n      timeZone: 'America/New_York',\n      year: 'numeric',\n      month: '2-digit',\n      day: '2-digit'\n    }).formatToParts(now);\n\n    const day = parseInt(parts.find(p => p.type === 'day').value);\n    const month = parseInt(parts.find(p 