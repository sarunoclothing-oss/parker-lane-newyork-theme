    "advanced_content_NiKQYN": {
      "type": "advanced-content",
      "blocks": {
        "liquid_HafUbC": {
          "type": "liquid",
          "settings": {
            "code": "<div class=\"marlow-trust-section\">\n  <div class=\"marlow-trust-grid\">\n\n    <!-- Free shipping -->\n    <div class=\"marlow-trust-item\">\n      <div class=\"marlow-trust-icon marlow-css-icon\">\n        <svg viewBox=\"0 0 64 64\" aria-hidden=\"true\">\n          <path d=\"M14 22h26v22H14z\"></path>\n          <path d=\"M40 30h8l6 7v7H40z\"></path>\n          <circle cx=\"23\" cy=\"47\" r=\"4\"></circle>\n          <circle cx=\"48\" cy=\"47\" r=\"4\"></circle>\n          <path d=\"M18 17h18\"></path>\n          <path d=\"M10 28h10\"></path>\n          <path d=\"M8 34h12\"></path>\n        </svg>\n      </div>\n      <h3>FREE SHIPPING</h3>\n      <p>Complimentary tracked delivery across the UK with UPS.</p>\n    </div>\n\n    <!-- Returns -->\n    <div class=\"marlow-trust-item\">\n      <div class=\"marlow-trust-icon marlow-css-icon\">\n        <svg viewBox=\"0 0 64 64\" aria-hidden=\"true\">\n          <path d=\"M18 18h28v34H18z\"></path>\n          <path d=\"M24 14v8\"></path>\n          <path d=\"M40 14v8\"></path>\n          <path d=\"M18 26h28\"></path>\n          <path d=\"M25 37h14\"></path>\n          <path d=\"M25 44h10\"></path>\n        </svg>\n      </div>\n      <h3>30-DAY RETURNS</h3>\n      <p>Not quite the right fit? Return your order within 30 days for complete peace of mind.</p>\n    </div>\n\n    <!-- Personal care -->\n    <div class=\"marlow-trust-item\">\n      <div class=\"marlow-trust-icon marlow-css-icon\">\n        <svg viewBox=\"0 0 64 64\" aria-hidden=\"true\">\n          <path d=\"M14 18h36v24H26l-10 8v-8h-2z\"></path>\n          <path d=\"M23 27h18\"></path>\n          <path d=\"M23 34h13\"></path>\n        </svg>\n      </div>\n      <h3>PERSONAL CARE</h3>\n      <p>Our team is here to help with sizing, orders, and questions whenever you need us.</p>\n    </div>\n\n  </div>\n</div>\n\n<style>\n  .marlow-trust-section {\n    width: 100vw;\n    margin-left: calc(50% - 50vw);\n    padding: 64px 24px;\n    background: #ffffff;\n    box-sizing: border-box;\n  }\n\n  .marlow-trust-grid {\n    max-width: 940px;\n    margin: 0 auto;\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    align-items: start;\n    gap: 40px 30px;\n  }\n\n  .marlow-trust-item {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    text-align: center;\n  }\n\n  .marlow-trust-icon {\n    width: 80px;\n    height: 80px;\n    border-radius: 50%;\n    background: #f4f4f4;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    margin-bottom: 22px;\n    transition: transform 0.3s ease, background-color 0.3s ease;\n  }\n\n  .marlow-trust-item:hover .marlow-trust-icon {\n    transform: translateY(-3px);\n    background: #ececec;\n  }\n\n  .marlow-css-icon svg {\n    width: 42px;\n    height: 42px;\n    fill: none;\n    stroke: #1a1a1a;\n    stroke-width: 2.2;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n  }\n\n  .marlow-trust-item h3 {\n    margin: 0 0 12px;\n    font-family: inherit;\n    font-size: 16px;\n    letter-spacing: 1.6px;\n    line-height: 1.4;\n    font-weight: 700;\n    color: #1a1a1a;\n    text-transform: uppercase;\n    text-wrap: balance;\n  }\n\n  .marlow-trust-item p {\n    margin: 0;\n    font-family: inherit;\n    font-size: 13.5px;\n    line-height: 1.65;\n    letter-spacing: 0.2px;\n    color: #5e5e5e;\n    max-width: 250px;\n    text-wrap: pretty;\n  }\n\n  @media screen and (max-width: 749px) {\n    .marlow-trust-section {\n      padding: 44px 20px;\n    }\n\n    .marlow-trust-grid {\n      grid-template-columns: 1fr;\n      gap: 36px;\n      max-width: 360px;\n    }\n\n    .marlow-trust-item:hover .marlow-trust-icon {\n      transform: none;\n      background: #f4f4f4;\n    }\n\n    .marlow-trust-icon {\n      width: 72px;\n      height: 72px;\n      margin-bottom: 16px;\n    }\n\n    .marlow-css-icon svg {\n      width: 38px;\n      height: 38px;\n    }\n\n    .marlow-trust-item h3 {\n      font-size: 15px;\n      letter-spacing: 1.4px;\n      margin-bottom: 8px;\n    }\n\n    .marlow-trust-item p {\n      font-size: 13px;\n      line-height: 1.55;\n      max-width: 260px;\n    }\n  }\n</style>",
