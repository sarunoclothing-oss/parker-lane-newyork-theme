          "settings": {
            "code": "<style>\n\n/* SECTION */\n.custom-usp-section {\n  background: #ffffff;\n  padding: 55px 20px;\n}\n\n/* GRID */\n.custom-usp-grid {\n  max-width: 1200px;\n  margin: 0 auto;\n\n  display: grid;\n  grid-template-columns: repeat(4, 1fr);\n\n  gap: 40px;\n\n  text-align: center;\n}\n\n/* ITEM */\n.custom-usp-item {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n}\n\n/* FILLED CIRCLE */\n.custom-usp-icon {\n  width: 82px;\n  height: 82px;\n\n  border-radius: 999px;\n\n  background: #9C8B7A;\n\n  display: flex;\n  align-items: center;\n  justify-content: center;\n\n  margin-bottom: 18px;\n\n  transition: all 0.25s ease;\n}\n\n/* HOVER */\n.custom-usp-item:hover .custom-usp-icon {\n  transform: translateY(-3px);\n}\n\n/* ICONS */\n.custom-usp-icon img {\n  width: 36px;\n  height: 36px;\n\n  object-fit: contain;\n\n  filter: brightness(0) invert(1);\n  opacity: 0.95;\n}\n\n/* TEXT */\n.custom-usp-title {\n  color: #9C8B7A;\n\n  font-size: 22px;\n  line-height: 1.25;\n\n  letter-spacing: 1.5px;\n  text-transform: uppercase;\n\n  font-weight: 400;\n\n  font-family: \"Helvetica Neue\", sans-serif;\n}\n\n/* MOBILE */\n@media screen and (max-width: 768px) {\n\n  .custom-usp-section {\n    padding: 45px 20px;\n  }\n\n  .custom-usp-grid {\n    grid-template-columns: repeat(2, 1fr);\n\n    gap: 50px 25px;\n  }\n\n  .custom-usp-icon {\n    width: 80px;\n    height: 80px;\n  }\n\n  .custom-usp-icon img {\n    width: 34px;\n    height: 34px;\n  }\n\n  .custom-usp-title {\n    font-size: 18px;\n    letter-spacing: 1.4px;\n  }\n}\n\n</style>\n\n<div class=\"custom-usp-section\">\n\n  <div class=\"custom-usp-grid\">\n\n    <!-- ECO -->\n    <div class=\"custom-usp-item\">\n\n      <div class=\"custom-usp-icon\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0662/8488/0137/files/eco-friendly-svgrepo-com.svg?v=1778707287\" alt=\"Eco Friendly\">\n      </div>\n\n      <div class=\"custom-usp-title\">\n        Ec