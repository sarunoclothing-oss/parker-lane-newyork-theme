    "faq_i7zEPy": {
      "type": "faq",
      "blocks": {
        "question_xfeEcY": {
          "type": "question",
          "settings": {
            "title": "Do you offer free shipping?",
            "text": "<p>Yes, we are pleased to offer complimentary tracked shipping on all orders across the UK. Orders are delivered with trusted US carriers, including UPS, so you can follow your parcel with clear tracking updates from dispatch to delivery.</p>"
          }
        },
        "question_8gBtKC": {
          "type": "question",
          "settings": {
            "title": "Can I return an item if it does not fit or if I am not satisfied?",
            "text": "<p>Of course. You may return your order within 30 days of receiving it. Items must be unworn, undamaged, and returned in their original condition.<br/><br/>To begin your return, simply contact us through our Contact Page or email us directly at <a href=\"mailto:support@marlow-london.com\">support@</a>parkerandlane-newyork.com. Our team will be happy to guide you through the return process.</p>"
          }
        },
        "question_mPzTFT": {
          "type": "question",
          "settings": {
            "title": "How can I track my order?",
            "text": "<p>Once your order has been dispatched, you will receive a confirmation email containing your personal tracking number.<br/><br/>You can follow your parcel at any time through our Order Tracking Page. Simply enter your tracking details to view the latest delivery updates.</p>"
          }
        },
        "question_89TDrQ": {
          "type": "question",
          "settings": {
            "title": "How do I choose the right size?",
            "text": "<p>Each product includes a detailed size guide to help you choose the most suitable fit.</p><p>If you are between sizes, we recommend selecting the larger size for a little extra comfort. If you need further guidance, our customer care team will be happy to assist.</p>"
          }
        },
        "question_7XBmpQ": {
          "type": "question",
          "settings": {
            "title": "What payment methods do you accept?",
            "text": "<p>You can complete your purchase securely using the following payment methods:</p><p>• Visa<br/>• Mastercard<br/>• American Express<br/>• Apple Pay<br/>• Google Pay<br/>• Shop Pay</p><p>All payments are processed securely through trusted payment providers.</p>"
          }
        },
        "question_Xmw8eF": {
          "type": "question",
          "settings": {
            "title": "Is my payment secure?",
            "text": "<p>Yes, your payment details are fully protected. We use industry standard SSL encryption to ensure your information remains safe and secure throughout the checkout process.</p>"
          }
        },
        "question_apGfjD": {
          "type": "question",
          "settings": {
            "title": "How long does shipping take?",
            "text": "<p>Orders are processed and dispatched within 24 hours on business days.</p><p>Delivery times may vary depending on your location, but we always strive to get your order to you as quickly as possible.</p><p>Once your order is on its way, you will receive a confirmation email with tracking details so you can follow your parcel at any time.</p>"
          }
        },
        "question_rjdbUg": {
          "type": "question",
          "settings": {
            "title": "How can I contact you if I have questions?",
            "text": "<p>Our customer care team will be happy to assist you. You can reach us through our Contact Page or email us directly at <a href=\"mailto:support@marlow-london.com\">support@</a>parkerandlane-newyork.com.</p><p>We aim to respond to all enquiries within 24 hours.</p>"
          }
        }
      },
