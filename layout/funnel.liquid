<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ page.title }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>body{margin:0;padding:0;background:#fff}.fnl .card h4 img{width:100%;height:auto;display:block;border-radius:12px;object-fit:cover}
</style>
  <style>
@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap');
  .fnl *{box-sizing:border-box;margin:0;padding:0}
  .fnl *{border-radius:0 !important}            /* square everything ... */
  .fnl-bar a{border-radius:8px !important}      /* ... except the bottom Shop Now button */
  .fnl{--blue:#5786bb;--blue-d:#456a98;--ink:#1a1a1a;--head:#000000;--muted:#5d6675;
       --muted2:#6b7585;--line:#e7eaef;--soft:#f4f6f9;--star:#f5b301;--green:#1f9d57;
       font-family:'Poppins',ui-sans-serif,system-ui,-apple-system,"Segoe UI",Roboto,Arial,sans-serif;
       color:var(--ink);background:#fff;line-height:1.6;font-size:17px;-webkit-font-smoothing:antialiased}
  .fnl .grid{max-width:1240px;margin:0 auto;padding:30px 24px 40px;display:grid;grid-template-columns:1fr 350px;gap:52px;align-items:start}
  .fnl .article{min-width:0}
  .fnl p{margin:0 0 15px}
  .fnl h1{font-size:33px;line-height:1.18;font-weight:800;color:var(--head);letter-spacing:-.01em;margin-bottom:14px}
  .fnl .dek{font-size:19px;color:var(--muted);margin-bottom:22px;padding-bottom:22px;border-bottom:1px solid var(--line)}
  .fnl h2{font-size:25px;line-height:1.25;font-weight:800;color:var(--head);margin:34px 0 14px}

  /* byline */
  .fnl .by{display:flex;align-items:center;gap:13px;margin-bottom:26px}
  .fnl .av{width:50px;height:50px;border-radius:50%;background:linear-gradient(135deg,#7fa0c8,#5786bb);color:#fff;font-weight:700;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
  .fnl .by .nm{font-weight:700;color:var(--blue);font-size:16px;line-height:1.2}
  .fnl .by .dt{font-size:13px;color:var(--muted2)}

  /* inline images */
  .fnl figure{margin:26px 0;text-align:center}
  .fnl figure img{width:100%;max-width:580px;display:inline-block;box-shadow:0 6px 20px rgba(20,40,70,.10)}
  .fnl figure.hero-fig img{max-width:640px}
  .fnl figcaption{font-size:13px;color:var(--muted2);text-align:center;margin-top:8px;font-style:italic}

  /* pull line */
  .fnl .pull{font-size:22px;line-height:1.4;font-weight:700;color:var(--head);border-left:4px solid var(--blue);padding:4px 0 4px 20px;margin:26px 0}

  /* three feature blocks (product breakdown) */
  .fnl .lay{border:1px solid var(--line);border-radius:14px;padding:22px 22px 6px;margin:22px 0;background:var(--soft)}
  .fnl .lay h3{font-size:18px;font-weight:800;color:var(--head);margin-bottom:8px;display:flex;align-items:center;gap:9px}
  .fnl .lay h3 .tag{background:var(--blue);color:#fff;font-size:12px;font-weight:700;padding:3px 10px;border-radius:20px;letter-spacing:.02em}

  /* CTA buttons */
  .fnl .cta{display:block;width:100%;text-align:center;background:var(--blue);color:#fff;text-decoration:none;
       font-weight:800;font-size:17px;letter-spacing:.01em;padding:17px 22px;border-radius:8px;border:none;cursor:pointer;
       white-space:nowrap;box-shadow:0 6px 16px rgba(87,134,187,.32);transition:background .15s,transform .12s;margin:8px 0}
  .fnl .cta:hover{background:var(--blue-d);transform:translateY(-1px)}
  .fnl .cta-wrap{margin:30px 0}
  .fnl .cta-sub{text-align:center;font-size:13px;color:var(--muted2);margin-top:8px}

  /* reviews */
  .fnl .revs{margin:26px 0}
  .fnl .rev{border:1px solid var(--line);border-radius:12px;padding:18px 20px;margin-bottom:14px;background:#fff}
  .fnl .rev .stars{color:var(--star);font-size:15px;letter-spacing:2px;margin-bottom:7px}
  .fnl .rev p{font-size:16px;margin-bottom:10px;color:#39424f}
  .fnl .rev .who{font-size:14px;font-weight:700;color:var(--head)}
  .fnl .rev .vf{font-size:12px;color:var(--green);font-weight:700}

  /* price / risk box */
  .fnl .pricebox{border:2px solid var(--blue);border-radius:14px;padding:24px;margin:24px 0;text-align:center;background:var(--soft)}
  .fnl .pricebox .now{font-size:34px;font-weight:800;color:var(--head)}
  .fnl .pricebox .was{font-size:18px;color:var(--muted2);text-decoration:line-through;margin-left:8px}
  .fnl .pricebox .pill{display:inline-block;background:#ffe8e0;color:#c2410c;font-weight:800;font-size:13px;padding:4px 12px;border-radius:20px;margin-bottom:12px;letter-spacing:.03em}

  /* guarantee */
  .fnl .guar{border:1px dashed var(--blue);border-radius:14px;padding:22px;margin:24px 0;display:flex;gap:16px;align-items:flex-start;background:#fff}
  .fnl .guar .seal{width:62px;height:62px;border-radius:50%;background:var(--blue);color:#fff;display:flex;align-items:center;justify-content:center;text-align:center;font-size:11px;font-weight:800;line-height:1.1;flex-shrink:0}
  .fnl .guar p{margin:0;font-size:15px;color:#475061}

  /* trust badges */
  .fnl .badges{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin:22px 0}
  .fnl .badge{display:flex;align-items:center;gap:10px;font-size:14px;font-weight:600;color:var(--head);background:var(--soft);border:1px solid var(--line);border-radius:10px;padding:12px 14px}
  .fnl .badge .ck{color:var(--green);font-weight:800}

  /* urgency */
  .fnl .urg{background:#fff7ed;border:1px solid #fed7aa;border-radius:12px;padding:18px 20px;margin:24px 0}
  .fnl .urg b{color:#c2410c}

  /* FAQ */
  .fnl .faq{margin:22px 0}
  .fnl .faq .q{font-weight:800;color:var(--head);font-size:16px;margin:18px 0 6px}
  .fnl .faq .a{font-size:16px;color:#475061;margin:0}

  /* SIDEBAR product card */
  .fnl .rail{position:sticky;top:20px}
  .fnl .card{border:1px solid var(--line);border-radius:16px;padding:20px;box-shadow:0 8px 26px rgba(20,40,70,.08)}
  .fnl .card .reco{font-size:13px;font-weight:800;letter-spacing:.14em;text-transform:uppercase;color:var(--muted2);margin-bottom:10px}
  .fnl .card .rate{display:flex;align-items:center;gap:8px;font-size:14px;color:var(--muted);margin-bottom:12px}
  .fnl .card .rate .s{color:var(--star);letter-spacing:1px}
  .fnl .card .pimg{width:100%;border-radius:12px;display:block;background:var(--soft)}
  .fnl .card h4{font-size:17px;font-weight:800;color:var(--head);margin:14px 0 10px;line-height:1.3}
  .fnl .card .feat{list-style:none;margin:0 0 14px;padding:0}
  .fnl .card .feat li{font-size:14px;color:#475061;padding:5px 0 5px 22px;position:relative}
  .fnl .card .feat li::before{content:"\2713";color:var(--green);font-weight:800;position:absolute;left:0}
  .fnl .swatches{display:flex;gap:8px;margin:4px 0 16px}
  .fnl .sw{width:26px;height:26px;border-radius:50%;border:2px solid #fff;box-shadow:0 0 0 1px var(--line)}
  .fnl .card .pr{text-align:center;margin-bottom:10px}
  .fnl .card .pr .now{font-size:24px;font-weight:800;color:var(--head)}
  .fnl .card .pr .was{font-size:15px;color:var(--muted2);text-decoration:line-through;margin-left:6px}

  /* sticky bottom bar */
  .fnl-bar{position:fixed;left:0;right:0;bottom:0;z-index:2147483647;background:rgba(255,255,255,.97);
       border-top:1px solid var(--line);box-shadow:0 -4px 18px rgba(20,40,70,.10);padding:8px 5px;backdrop-filter:blur(4px)}
  .fnl-bar .in{max-width:100%;margin:0;display:flex;align-items:center;gap:14px}
  .fnl-bar .meta{flex:1;min-width:0}
  .fnl-bar .meta .t{font-weight:800;color:#16202e;font-size:15px;line-height:1.2;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
       font-family:'Poppins',ui-sans-serif,system-ui,-apple-system,"Segoe UI",Roboto,Arial,sans-serif}
  .fnl-bar .meta .p{font-size:13px;color:#5d6675;font-family:'Poppins',ui-sans-serif,system-ui,Arial,sans-serif}
  .fnl-bar .meta .p b{color:#16202e}
  .fnl-bar a{display:block;width:100%;max-width:760px;margin:0 auto;text-align:center;background:#5786bb;color:#fff;text-decoration:none;font-weight:800;font-size:17px;letter-spacing:.01em;padding:18px 22px;border-radius:8px;white-space:normal;box-shadow:0 6px 16px rgba(87,134,187,.32);font-family:'Poppins',ui-sans-serif,system-ui,Arial,sans-serif}
  .fnl-bar a:hover{background:#456a98}
  .fnl{padding-bottom:80px}

  /* FOOTER */
  .fnl .fnl-footer{max-width:760px;margin:0 auto;padding:36px 24px 50px;border-top:1px solid var(--line);text-align:center}
  .fnl .fnl-footer .cta{max-width:460px;margin:0 auto 22px}
  .fnl .fnl-footer p{font-size:13px;color:var(--muted);margin:6px 0}
  .fnl .fnl-footer .copy{font-size:12px;color:var(--muted2);margin-top:14px}
  .fnl .fnl-footer p a{color:var(--blue);text-decoration:none}
  .fnl .fnl-footer .cta{color:#fff}

  /* responsive */
  @media(max-width:900px){
    .fnl .grid{grid-template-columns:1fr;gap:26px}
    .fnl .rail{position:static;order:2}
    .fnl h1{font-size:27px}
    .fnl .dek{font-size:17px}
    .fnl h2{font-size:22px}
  }
  @media(max-width:480px){
    .fnl{font-size:16px}
    .fnl .grid{padding:20px 16px 36px}
    .fnl h1{font-size:24px}
    .fnl .badges{grid-template-columns:1fr}
    .fnl-bar .meta .t{font-size:14px}
  }
  </style>
  {{ content_for_header }}
</head>
<body>
  {{ content_for_layout }}
</body>
</html>
